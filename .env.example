# Copy to .env and fill in. .env is git-ignored — NEVER commit real secrets.

# ── Data source for the daily backfill ──────────────────────────────────
# 'upstox' uses the historical API (creds below); 'yfinance' needs none.
DATA_ADAPTER=upstox

# ── Upstox historical API (Phase 0 daily backfill) ──────────────────────
# OHLCV hits real exchange data regardless of env, so 'prod' is fine.
# The access token EXPIRES DAILY (~03:30 IST) — regenerate it the day we
# run the one-time 10-year backfill.
UPSTOX_ENV=prod
UPSTOX_PROD_API_KEY=
UPSTOX_PROD_API_SECRET=
UPSTOX_PROD_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=http://127.0.0.1:8000/upstox/callback

# ── Alerts (Phase 4 paper trading — NOT needed for Phase 0) ─────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_EMAIL_FROM=
ALERT_EMAIL_PASSWORD=
ALERT_EMAIL_TO=
ALERT_EMAIL_SMTP_HOST=smtp.gmail.com
ALERT_EMAIL_SMTP_PORT=587
